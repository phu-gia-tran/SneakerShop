@model IEnumerable<Sneaker.Models.SanPham>

@{
    ViewBag.Title = "Index";
    Layout = "~/Views/Shared/_Layout.cshtml";
    Func<decimal?, string> FormatCurrency = value => string.Format("{0:N0}₫", value ?? 0);
}
@Html.Partial("~/Views/Shared/Partials/_banner.cshtml")
<style>
    .product {
        border-radius: 18px;
        background: #fff;
        box-shadow: 0 10px 24px rgba(0, 0, 0, 0.08);
        transition: transform 0.25s ease, box-shadow 0.25s ease;
        height: 100%;
    }

    .product:hover {
        transform: translateY(-5px);
        box-shadow: 0 16px 30px rgba(0, 0, 0, 0.12);
    }

    .product .img-prod {
        display: flex;
        justify-content: center;
        align-items: center;
        min-height: 220px;
    }

    .product .img-prod img {
        object-fit: contain;
        margin: 0 auto;
    }

    .product .text .bottom-area a.add-to-cart, .product .text .bottom-area a.buy-now {
        font-size: 13px;
        color: #000000;
        text-transform: uppercase;
        font-weight: 300;
    }

        .product .text .bottom-area a.add-to-cart i, .product .text .bottom-area a.buy-now i {
            font-size: 16px;
        }

    .product .text .bottom-area a.add-to-cart {
        background: #000000;
        color: #ffffff;
        border-radius: 999px;
    }

        .product .text .bottom-area a.add-to-cart:hover {
            background: #ffffff;
            color: #000000;
        }

    /* Them*/
    .product .text .bottom-area a.buy-now {
        background: #ffffff;
        color: #000000;
        border-radius: 999px;
        border: 1px solid #ddd;
    }

        .product .text .bottom-area a.buy-now:hover {
            background: #000000;
            color: #ffffff;
        }
</style>
<section class="ftco-section ftco-no-pt ftco-no-pb">
    <div class="container">
        @Html.Partial("~/Views/Shared/Partials/_services.cshtml")
    </div>
</section>

<section class="ftco-section bg-light">
    <div class="container">
        <div class="row justify-content-center mb-3 pb-3">
            <div class="col-md-12 heading-section text-center ftco-animate">
                <h2 class="mb-4">Khám phá bộ sưu tập mới nhất</h2>
              
            </div>
        </div>
    </div>
    <div class="container">
        <div class="row">
            @if (ViewBag.DatabaseWarning != null)
            {
                <div class="col-12">
                    <div class="alert alert-warning text-center">@ViewBag.DatabaseWarning</div>
                </div>
            }
            @foreach (var item in Model)
            {
                <div class="col-sm-12 col-md-6 col-lg-3 ftco-animate d-flex">
                    <div class="product d-flex flex-column">
                        <a href="#" class="img-prod">
                            <img class="img-fluid" src="@Url.Content("~/Assets/Images/Products/"+item.AnhDD)" alt="@item.TenSP" width="300" height="300">
                            <div class="overlay"></div>
                        </a>
                        <div class="text py-3 pb-4 px-3">
                            <div class="d-flex">
                                <div class="cat">
                                    <span>Giày thể thao</span>
                                </div>
                                <div class="rating">
                                    <p class="text-right mb-0">
                                        <a href="#"><span class="ion-ios-star-outline"style="color:black"></span></a>
                                        <a href="#"><span class="ion-ios-star-outline"style="color:black"></span></a>
                                        <a href="#"><span class="ion-ios-star-outline"style="color:black"></span></a>
                                        <a href="#"><span class="ion-ios-star-outline"style="color:black"></span></a>
                                        <a href="#"><span class="ion-ios-star-outline"style="color:black"></span></a>
                                    </p>
                                </div>
                            </div>
                            <h3><a href="#">@item.TenSP</a></h3>
                            <div class="pricing">
                                <p class="price"><span>@FormatCurrency(item.GiaBan)</span></p>
                            </div>
                            <p class="bottom-area d-flex px-3">
                                <a href="@Url.Action("Detail","Shop", new { id = item.MaSP})" class="add-to-cart text-center py-2 mr-1"><span>Xem chi tiết<i class="ion-ios-add ml-1"></i></span></a>
                                <a href="@Url.Action("AddToCart", "Cart", new { @iMaSP = item.MaSP, @strURL = Request.Url.ToString() })" class="buy-now text-center py-2">Thêm vào giỏ hàng<span><i class="ion-ios-cart ml-1"></i></span></a>
                            </p>
                        </div>
                    </div>
                </div>
            }
        </div>
    </div>
</section>




@Html.Partial("~/Views/Shared/Partials/_feedback.cshtml")
@Html.Partial("~/Views/Shared/Partials/_followus.cshtml")
